<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RIOT MD - Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .pairing-result {
            background: #0a0a0a;
            border: 1px solid #00ff41;
            padding: 20px;
            border-radius: 8px;
            margin-top: 20px;
        }
        .pairing-code {
            font-size: 28px;
            font-weight: bold;
            color: #00ff41;
            font-family: monospace;
            text-align: center;
            padding: 15px;
            background: #000;
            border-radius: 5px;
            letter-spacing: 2px;
        }
        .instructions {
            margin-top: 15px;
            padding-left: 20px;
        }
        .instructions li {
            margin: 8px 0;
        }
        .loading {
            text-align: center;
            padding: 20px;
            color: #888;
        }
    </style>
</head>
<body>
    <div class="terminal-header">
        <div class="logo">RIOT<span>MD</span></div>
        <nav class="nav">
            <a href="/dashboard" class="active">Dashboard</a>
            <a href="/users">Users</a>
            <a href="/sessions">Sessions</a>
            <a href="/settings">Settings</a>
            <a href="/logs">Logs</a>
        </nav>
    </div>
    
    <div class="dashboard-container">
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">Active Sessions</div>
                <div class="stat-value" id="activeSessions">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">Total Users</div>
                <div class="stat-value" id="totalUsers">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">Commands Loaded</div>
                <div class="stat-value">295</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">Uptime</div>
                <div class="stat-value" id="uptime">0s</div>
            </div>
        </div>
        
        <div class="pairing-form">
            <h2>🔐 Connect WhatsApp Account</h2>
            <p>Enter your phone number with country code to get a pairing code</p>
            
            <div class="form-group">
                <label>Phone Number (with country code)</label>
                <input type="tel" id="phoneNumber" placeholder="例: 254712345678">
                <small>Example: 254712345678 (Kenya) or 14155552671 (USA)</small>
            </div>
            
            <button class="btn" id="pairBtn" onclick="generatePairingCode()">Generate Pairing Code</button>
            
            <div id="pairingResult" style="display: none;"></div>
        </div>
        
        <div class="table-container">
            <h3>Active Sessions</h3>
            <table>
                <thead>
                    <tr><th>Phone Number</th><th>Status</th><th>Action</th></tr>
                </thead>
                <tbody id="sessionsList">
                    <tr><td colspan="3" class="loading">Loading sessions...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    
    <script>
        async function generatePairingCode() {
            const phoneNumber = document.getElementById('phoneNumber').value;
            if (!phoneNumber) {
                alert('Please enter your phone number');
                return;
            }
            
            const btn = document.getElementById('pairBtn');
            const originalText = btn.textContent;
            btn.textContent = 'Generating...';
            btn.disabled = true;
            
            try {
                const response = await fetch('/api/pair', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ phoneNumber: phoneNumber })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    document.getElementById('pairingResult').innerHTML = `
                        <div class="pairing-result">
                            <h3>📱 Your Pairing Code</h3>
                            <div class="pairing-code">${data.code}</div>
                            <div class="instructions">
                                <h4>Instructions:</h4>
                                <ol>
                                    <li>Open WhatsApp on your phone</li>
                                    <li>Go to <strong>Settings → Linked Devices</strong></li>
                                    <li>Tap <strong>"Link a Device"</strong></li>
                                    <li>Select <strong>"Link with phone number"</strong></li>
                                    <li>Enter the code above: <strong>${data.code}</strong></li>
                                    <li>Your bot will connect automatically!</li>
                                </ol>
                                <p style="color: #00ff41; margin-top: 10px;">✓ Waiting for verification...</p>
                            </div>
                        </div>
                    `;
                    document.getElementById('pairingResult').style.display = 'block';
                    
                    // Refresh sessions after 5 seconds
                    setTimeout(loadSessions, 5000);
                    setTimeout(loadSessions, 15000);
                } else {
                    alert('Error: ' + (data.error || 'Unknown error'));
                }
            } catch (error) {
                alert('Error generating code: ' + error.message);
            } finally {
                btn.textContent = originalText;
                btn.disabled = false;
            }
        }
        
        async function loadSessions() {
            try {
                const response = await fetch('/api/sessions');
                const data = await response.json();
                const tbody = document.getElementById('sessionsList');
                
                if (data.sessions && data.sessions.length > 0) {
                    tbody.innerHTML = data.sessions.map(s => `
                        <tr>
                            <td>${s.phoneNumber || 'Pending'}</td>
                            <td><span class="status status-online">${s.status}</span></td>
                            <td><button onclick="disconnectSession('${s.id}')" class="btn btn-danger" style="padding: 5px 10px; font-size: 12px;">Disconnect</button></td>
                        </tr>
                    `).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="3">No active sessions. Generate a pairing code above!</td></tr>';
                }
            } catch (e) {
                console.error('Error loading sessions:', e);
                document.getElementById('sessionsList').innerHTML = '<tr><td colspan="3">Error loading sessions</td></tr>';
            }
        }
        
        async function loadStats() {
            try {
                const response = await fetch('/api/status');
                const data = await response.json();
                document.getElementById('activeSessions').textContent = data.activeSessions || 0;
                document.getElementById('totalUsers').textContent = data.totalUsers || 0;
                const uptime = Math.floor(data.uptime || 0);
                document.getElementById('uptime').textContent = uptime + 's';
            } catch (e) {
                console.error('Error loading stats:', e);
            }
        }
        
        async function disconnectSession(sessionId) {
            if (confirm('Disconnect this WhatsApp session?')) {
                alert('Session disconnect feature coming soon. Restart Railway to clear all sessions.');
            }
        }
        
        // Load data on page load and every 10 seconds
        loadStats();
        loadSessions();
        setInterval(loadStats, 10000);
        setInterval(loadSessions, 10000);
    </script>
</body>
</html>
