<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RIOT MD - Settings</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="terminal-header">
        <div class="logo">RIOT<span>MD</span></div>
        <nav class="nav">
            <a href="/dashboard">Dashboard</a>
            <a href="/users">Users</a>
            <a href="/sessions">Sessions</a>
            <a href="/settings" class="active">Settings</a>
            <a href="/logs">Logs</a>
        </nav>
    </div>
    
    <div class="dashboard-container">
        <h2>⚙️ Bot Settings</h2>
        <div class="pairing-form">
            <div class="form-group">
                <label>Bot Name</label>
                <input type="text" value="<%= config.BOT_NAME %>" readonly>
            </div>
            <div class="form-group">
                <label>Version</label>
                <input type="text" value="<%= config.BOT_VERSION %>" readonly>
            </div>
            <div class="form-group">
                <label>Command Prefix</label>
                <input type="text" value="<%= config.PREFIX %>" readonly>
            </div>
            <div class="form-group">
                <label>Database Type</label>
                <input type="text" value="<%= config.DB_TYPE %>" readonly>
            </div>
            <p><em>Settings can be changed by updating your Railway environment variables.</em></p>
        </div>
    </div>
</body>
</html>
